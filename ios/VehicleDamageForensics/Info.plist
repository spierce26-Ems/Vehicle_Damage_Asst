<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- NOTE(AI Developer): Privacy usage strings per HANDOFF_TO_AI_DEVELOPER.md
	     Section 3. Worded to match the v1 "investigative documentation" scope
	     decision (2026-07) rather than implying forensic/court-admissible
	     certainty, consistent with the report/UI language sweep already
	     done in the Swift source (see MatchResult.disclaimerText). -->
	<key>NSCameraUsageDescription</key>
	<string>This app uses the camera to capture vehicle damage photos for investigative documentation.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Import existing damage photos from your photo library for a case.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Save generated documentation reports and photos to your photo library.</string>
	<!-- NOTE(AI Developer), corrected 2026-07-07: CameraService.swift and
	     CaptureViewModel.swift both instantiate CLLocationManager and call
	     requestWhenInUseAuthorization() to geo-tag capture location for
	     IncidentLocation (Case.swift). This key MUST be present: calling
	     that API without it crashes the app immediately at runtime. -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Used to record the location where damage photos were captured.</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- NOTE(AI Developer), corrected 2026-07-07: Removed
	     UIRequiredDeviceCapabilities entirely. This key is an install-time
	     App Store/device gate, not a debug-launch check, but it was wrong
	     either way: "armv7" is dead cruft from an old 32-bit template (our
	     deployment target is iOS 17, arm64-only, so this entry is
	     meaningless) and "arkit" hard-blocks install on any device without
	     an A9+ chip -- which contradicts LiDARService.isAvailable, which
	     already gracefully degrades when LiDAR/ARKit isn't present. Camera
	     capture, case management, and PDF reporting all work fine without
	     ARKit; only the optional LiDAR scan step needs it. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
